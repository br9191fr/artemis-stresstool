<!--
  Add these dependencies to your existing pom.xml <dependencies> section.
  They bring in the OpenTelemetry SDK and OTLP/gRPC exporter.
-->

<properties>
    <!-- Add this alongside your existing properties -->
    <otel.version>1.38.0</otel.version>
</properties>

<dependencies>

    <!-- OpenTelemetry API -->
    <dependency>
        <groupId>io.opentelemetry</groupId>
        <artifactId>opentelemetry-api</artifactId>
        <version>${otel.version}</version>
    </dependency>

    <!-- OpenTelemetry SDK -->
    <dependency>
        <groupId>io.opentelemetry</groupId>
        <artifactId>opentelemetry-sdk</artifactId>
        <version>${otel.version}</version>
    </dependency>

    <!-- OTLP/gRPC metrics exporter -->
    <dependency>
        <groupId>io.opentelemetry</groupId>
        <artifactId>opentelemetry-exporter-otlp</artifactId>
        <version>${otel.version}</version>
    </dependency>

    <!-- Semantic conventions (ResourceAttributes) -->
    <dependency>
        <groupId>io.opentelemetry.semconv</groupId>
        <artifactId>opentelemetry-semconv</artifactId>
        <version>1.29.0</version>
    </dependency>

</dependencies>

<!--
  The maven-shade-plugin already in your pom.xml handles merging.
  Add this transformer to the existing <transformers> list to merge
  the gRPC service descriptors correctly:
-->
<transformer implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
<!--
  (This transformer is likely already present in your shade config —
   check before adding it twice.)
-->
